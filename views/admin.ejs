<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-dark bg-dark border-bottom border-secondary">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">Feedback Board</a>
      <div>
        <a href="/feedback" class="btn btn-outline-light btn-sm me-2">Submit</a>
        <a href="/admin" class="btn btn-outline-light btn-sm">Admin</a>
        <form action="/logout" method="POST" class="d-inline">
          <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <div class="container py-5">
    <h2 class="mb-4">Admin Dashboard</h2>

    <div class="row g-3 mb-4" id="summaryCards">
      <div class="col-sm-6 col-lg-3">
        <div class="card border-primary h-100">
          <div class="card-body">
            <h6 class="card-subtitle text-secondary mb-1">Total Feedbacks</h6>
            <h2 class="card-text text-primary mb-0" id="totalCount">-</h2>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="card border-secondary h-100">
          <div class="card-body">
            <h6 class="card-subtitle text-secondary mb-1">New</h6>
            <h2 class="card-text text-secondary mb-0" id="newCount">-</h2>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="card border-warning h-100">
          <div class="card-body">
            <h6 class="card-subtitle text-secondary mb-1">In Review</h6>
            <h2 class="card-text text-warning mb-0" id="inReviewCount">-</h2>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="card border-success h-100">
          <div class="card-body">
            <h6 class="card-subtitle text-secondary mb-1">Resolved</h6>
            <h2 class="card-text text-success mb-0" id="resolvedCount">-</h2>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow">
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
              <tr>
                <th>Title</th>
                <th>Message</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="feedbacksTableBody"></tbody>
          </table>
        </div>

        <div id="loadingSkeleton" class="d-none">
          <div class="placeholder-row">
            <div class="placeholder-glow d-flex align-items-center py-3 border-bottom border-secondary">
              <div class="me-3" style="flex:2"><span class="placeholder col-8"></span></div>
              <div class="me-3" style="flex:3"><span class="placeholder col-10"></span></div>
              <div class="me-3" style="flex:1"><span class="placeholder col-6"></span></div>
              <div class="me-3" style="flex:1"><span class="placeholder col-7"></span></div>
              <div style="flex:1"><span class="placeholder col-9"></span></div>
            </div>
            <div class="placeholder-glow d-flex align-items-center py-3 border-bottom border-secondary">
              <div class="me-3" style="flex:2"><span class="placeholder col-6"></span></div>
              <div class="me-3" style="flex:3"><span class="placeholder col-8"></span></div>
              <div class="me-3" style="flex:1"><span class="placeholder col-5"></span></div>
              <div class="me-3" style="flex:1"><span class="placeholder col-7"></span></div>
              <div style="flex:1"><span class="placeholder col-9"></span></div>
            </div>
            <div class="placeholder-glow d-flex align-items-center py-3">
              <div class="me-3" style="flex:2"><span class="placeholder col-7"></span></div>
              <div class="me-3" style="flex:3"><span class="placeholder col-9"></span></div>
              <div class="me-3" style="flex:1"><span class="placeholder col-4"></span></div>
              <div class="me-3" style="flex:1"><span class="placeholder col-7"></span></div>
              <div style="flex:1"><span class="placeholder col-9"></span></div>
            </div>
          </div>
        </div>

        <div id="emptyState" class="d-none">
          <div class="text-center py-5">
            <svg width="64" height="64" fill="#6c757d" viewBox="0 0 16 16">
              <path d="M2 1a1 1 0 0 0-1 1v9.5A1.5 1.5 0 0 0 2.5 13h11a1.5 1.5 0 0 0 1.5-1.5V2a1 1 0 0 0-1-1H2zm0 1h11v9.5a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5V2z"/>
              <path d="M5.5 5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1h-5zm0 2a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1h-3z"/>
              <path d="M8 9.5a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0v-1a.5.5 0 0 1 .5-.5z"/>
            </svg>
            <h5 class="mt-3">No feedbacks yet</h5>
            <p class="text-secondary mb-3">Submit feedbacks from the form page and they will appear here.</p>
            <a href="/feedback" class="btn btn-primary">Submit Feedback</a>
          </div>
        </div>

        <div id="errorState" class="d-none">
          <div class="text-center py-5">
            <svg width="64" height="64" fill="#dc3545" viewBox="0 0 16 16">
              <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zM7 5a1 1 0 0 1 2 0v3a1 1 0 0 1-2 0V5zm0 5a1 1 0 1 1 2 0 1 1 0 0 1-2 0z"/>
            </svg>
            <h5 class="mt-3 text-danger">Failed to load feedbacks</h5>
            <p class="text-secondary mb-3" id="errorStateMessage">Something went wrong.</p>
            <button class="btn btn-outline-light" id="retryBtn">Retry</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="successToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="toast-header">
        <svg class="me-2 text-success" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>
        <strong class="me-auto">Success</strong>
        <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
      </div>
      <div class="toast-body" id="successToastMessage">Status updated successfully.</div>
    </div>

    <div id="errorToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="toast-header">
        <svg class="me-2 text-danger" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zM7 5a1 1 0 0 1 2 0v3a1 1 0 0 1-2 0V5zm0 5a1 1 0 1 1 2 0 1 1 0 0 1-2 0z"/></svg>
        <strong class="me-auto">Error</strong>
        <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
      </div>
      <div class="toast-body" id="errorToastMessage">Something went wrong.</div>
    </div>
  </div>

  <div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h6 class="modal-title">Confirm Status Change</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p class="mb-0" id="confirmMessage">Change status?</p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="cancelConfirmBtn">Cancel</button>
          <button type="button" class="btn btn-primary" id="confirmBtn">Confirm</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/admin.js"></script>
</body>
</html>
